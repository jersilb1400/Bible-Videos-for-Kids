# ---------------------------------------------------------------------------
# Bible Story Studio — environment configuration
#
# Every provider falls back to a fully offline LOCAL implementation when its
# key is missing, so the pipeline runs end-to-end with zero credentials.
# Fill these in to switch individual stages over to production providers.
# ---------------------------------------------------------------------------

# --- LLM (story, script, metadata) ------------------------------------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model used for creative writing. You mentioned Nous Hermes already.
OPENROUTER_MODEL=nousresearch/hermes-4-405b
# A cheaper/faster model for structured metadata + moderation.
OPENROUTER_UTILITY_MODEL=meta-llama/llama-3.3-70b-instruct

# --- Image generation (character-consistent keyframes) ----------------------
# "local" (offline SVG), "fal", or "self-host" (your Hetzner ComfyUI endpoint)
IMAGE_PROVIDER=local
FAL_API_KEY=
# fal model slug for stills, e.g. flux-2 multi-ref for character consistency
FAL_IMAGE_MODEL=fal-ai/flux-2
COMFYUI_ENDPOINT=

# --- Animation (image -> video) ---------------------------------------------
# "local" (offline ken-burns), "fal", or "self-host"
VIDEO_PROVIDER=local
# fal model slug for image-to-video; PixVerse is the cartoon/anime specialist.
FAL_VIDEO_MODEL=fal-ai/pixverse/v4.5/image-to-video

# --- Voiceover (TTS) --------------------------------------------------------
# "local" (offline placeholder), "elevenlabs", or "kokoro"
TTS_PROVIDER=local
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Self-hosted Kokoro endpoint (OpenAI-compatible /v1/audio/speech)
KOKORO_ENDPOINT=

# --- Music ------------------------------------------------------------------
# "local" (offline gentle pad), "suno"
MUSIC_PROVIDER=local
SUNO_API_KEY=

# --- Publishing (YouTube Data API v3) ---------------------------------------
# "mock" (writes a manifest, uploads nothing) or "youtube"
PUBLISH_PROVIDER=mock
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# unlisted | private | public — start unlisted for a human review gate.
YOUTUBE_PRIVACY=unlisted

# --- Pipeline behaviour -----------------------------------------------------
# Stop and require approval before publishing (recommended for kids content).
REQUIRE_APPROVAL=false
OUTPUT_DIR=./out
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
